# ============================================================
# Pumpky Environment Variables
# ============================================================
# Copy to .env.local for local development.
# For production, configure these in Vercel/Render/Railway/etc.

# ------------------------------------------------------------
# Core
# ------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Pumpky"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
# Local example:
# postgresql://postgres:password@localhost:5432/pumpky
DATABASE_URL="postgresql://postgres:password@localhost:5432/pumpky"

# ------------------------------------------------------------
# Data provider mode
# ------------------------------------------------------------
# false = demo/mock provider
# true  = use live provider adapter layer (currently scaffolded)
USE_LIVE_DATA="false"
DEMO_MODE="true"

# ------------------------------------------------------------
# Optional live data providers
# ------------------------------------------------------------
DEXSCREENER_API_KEY=""
COINGECKO_API_KEY=""
BIRDEYE_API_KEY=""
DEFINED_API_KEY=""
MORALIS_API_KEY=""

# ------------------------------------------------------------
# Optional AI provider keys
# ------------------------------------------------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ------------------------------------------------------------
# Optional auth provider keys (if auth is added later)
# ------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
